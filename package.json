{
  "name": "@outfoxx/sunday",
  "version": "0.0.0-dev",
  "description": "Sunday 🙏 The framework of REST for TypeScript/JavaScript",
  "packageManager": "bun@1.3.9",
  "main": "build/main/index.js",
  "module": "build/esm/index.js",
  "esnext": "build/esnext/index.js",
  "types": "build/main/index.d.ts",
  "files": [
    "src",
    "build",
    "LICENSE.txt",
    "README.md"
  ],
  "scripts": {
    "test": "bun test -r ./test/setup.ts",
    "test:watch": "bun test -r ./test/setup.ts --watch",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "build": "tsc --build tsconfig-main.json tsconfig-esm.json tsconfig-esnext.json",
    "build:watch": "tsc --build tsconfig-main.json tsconfig-esm.json tsconfig-esnext.json --watch",
    "clean": "rimraf build docs reports",
    "pretty": "prettier src test",
    "lint": "eslint -f json -o reports/lint.json src test",
    "lint:html": "eslint -f html -o reports/lint.html src test",
    "docs": "typedoc --excludeInternal --excludePrivate src/index.ts",
    "prepublishOnly": "bun run clean && bun run lint && bun run build",
    "build:stub": "dts-bundle-generator --config tools/stub/dts-bundle.json --project tools/stub/tsconfig.json"
  },
  "husky": {
    "hooks": {
      "pre-commit": "pretty-quick --staged && lint-staged"
    }
  },
  "lint-staged": {
    "*.{ts,js,tsx,jsx}": [
      "eslint"
    ]
  },
  "keywords": [
    "HTTP",
    "REST",
    "fetch"
  ],
  "author": "kdubb",
  "license": "Apache-2.0",
  "dependencies": {
    "@js-joda/core": "^5.7.0",
    "cbor-redux": "^1.0.0",
    "tslib": "^2.8.1",
    "uri-template": "^2.0.0"
  },
  "peerDependencies": {
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.9",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "dts-bundle-generator": "^9.5.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "fetch-mock": "^12.6.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "install": "^0.13.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "pretty-quick": "^4.2.2",
    "rimraf": "^6.1.3",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3"
  }
}
